# .env sí puede contener secretos reales (a diferencia de js/config.js,
# que solo tiene la publishable key de Supabase y los client_id/tenant_id
# de Microsoft — ninguno de los dos es secreto, están pensados para vivir
# en el navegador; la protección real es RLS del lado de Supabase).
.env
.env.*

# Config local de Claude Code (específica de esta máquina, no del proyecto)
.claude/settings.local.json
